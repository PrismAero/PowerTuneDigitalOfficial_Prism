# .clangd configuration for PowerTune Qt 6 project
# Qt include paths are provided by the build tree compile database generated by CMake.
# Regenerate with:
#   cmake -S . -B build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
# or a preset that enables CMAKE_EXPORT_COMPILE_COMMANDS.

CompileFlags:
  CompilationDatabase: build

Diagnostics:
  Suppress:
    - "pp_file_not_found"
    - "drv_unknown_argument"

  ClangTidy:
    Add: []
    Remove:
      - "*"

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
  Designators: true

Hover:
  ShowAKA: true

Completion:
  AllScopes: true
